# GEMINI_API_KEY: Gemini API 키 (로컬·배포 공통 필수)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Cursor Proxy (OpenAI 호환) — manual.md 참고
CURSOR_PROXY_BASE_URL="http://168.107.36.218:8765/v1"
CURSOR_PROXY_API_KEY="YOUR_CURSOR_PROXY_API_KEY"

# Cline Pass (OAuth) — cline.bot 구독 모델 (GLM-5.2 등)
# 토큰은 설정 화면에서 OAuth 로그인으로 저장 (env 아님)
CLINE_PASS_BASE_URL="https://api.cline.bot"

# 채팅 기본 LLM 제공자: gemini | cursor-proxy | cline-pass
BUILDME_LLM_PROVIDER=gemini

# BUILDME_ADMIN_PASSWORD: 관리자 설정 화면 비밀번호 (기본값 admin)
BUILDME_ADMIN_PASSWORD=admin

# 로컬 개발 로그 (1=항상 켜기, 0=끄기, 미설정=로컬 npm run dev 시 자동 켜짐)
BUILDME_DEV_LOG=1

# APP_URL: 배포 URL (선택)
APP_URL="http://localhost:3000"
